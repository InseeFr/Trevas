<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>fr.insee.trevas</groupId>
        <artifactId>trevas-parent</artifactId>
        <version>2.4.0-SNAPSHOT</version>
    </parent>

    <artifactId>vtl-parser</artifactId>
    <name>VTL Parser</name>
    <description>Artifacts generated by Antlr from the VTL grammar files</description>
    <version>2.4.0-SNAPSHOT</version>

    <!--    Warning: not lastest, align with version embedded by Spark-->
    <properties>
        <antlr4.version>4.9.3</antlr4.version>
        <sonar.coverage.jacoco.xmlReportPaths>
            ${project.basedir}/../coverage/target/site/jacoco-aggregate/jacoco.xml
        </sonar.coverage.jacoco.xmlReportPaths>
    </properties>

    <dependencies>
        <dependency>
            <groupId>org.antlr</groupId>
            <artifactId>antlr4-runtime</artifactId>
            <version>${antlr4.version}</version>
            <scope>compile</scope>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.antlr</groupId>
                <artifactId>antlr4-maven-plugin</artifactId>
                <version>${antlr4.version}</version>
                <executions>
                    <execution>
                        <configuration>
                            <listener>true</listener>
                            <visitor>true</visitor>
                            <libDirectory>src/main/antlr4/fr/insee/vtl/parser</libDirectory>
                        </configuration>
                        <id>antlr</id>
                        <goals>
                            <goal>antlr4</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>
            <plugin>
                <!-- Build the unshaded jar early (process-classes) so shade can transform it
                     before tests run. Skip the default jar execution that would otherwise
                     overwrite the shaded jar at the package phase. -->
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-jar-plugin</artifactId>
                <executions>
                    <execution>
                        <id>default-jar</id>
                        <phase>none</phase>
                    </execution>
                    <execution>
                        <id>pre-shade-jar</id>
                        <phase>process-classes</phase>
                        <goals>
                            <goal>jar</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-shade-plugin</artifactId>
                <version>3.5.0</version>
                <executions>
                    <execution>
                        <id>shade-antlr</id>
                        <phase>process-classes</phase>
                        <goals>
                            <goal>shade</goal>
                        </goals>
                        <configuration>
                            <createDependencyReducedPom>false</createDependencyReducedPom>
                            <artifactSet>
                                <includes>
                                    <include>org.antlr:antlr4-runtime</include>
                                </includes>
                            </artifactSet>

                            <relocations>
                                <relocation>
                                    <pattern>org.antlr.v4</pattern>
                                    <shadedPattern>fr.insee.vtl.parser.antlr4</shadedPattern>
                                </relocation>
                            </relocations>

                        </configuration>
                    </execution>
                </executions>
            </plugin>
            <plugin>
                <!-- Inject a JPMS module-info into the shaded JAR. The source module-info.java
                     only exports unshaded packages (so Surefire can read target/classes during test);
                     this execution overwrites the JAR's module-info.class with one that also exports
                     the relocated fr.insee.vtl.parser.antlr4.* packages produced by shade. -->
                <groupId>org.moditect</groupId>
                <artifactId>moditect-maven-plugin</artifactId>
                <version>1.2.2.Final</version>
                <executions>
                    <execution>
                        <id>add-shaded-module-info</id>
                        <phase>process-classes</phase>
                        <goals>
                            <goal>add-module-info</goal>
                        </goals>
                        <configuration>
                            <overwriteExistingFiles>true</overwriteExistingFiles>
                            <outputDirectory>${project.build.directory}</outputDirectory>
                            <modules>
                                <module>
                                    <file>${project.build.directory}/${project.build.finalName}.jar</file>
                                    <moduleInfo>
                                        <name>fr.insee.vtl.parser</name>
                                        <exports>
                                            fr.insee.vtl.parser;
                                            fr.insee.vtl.parser.antlr4.runtime;
                                            fr.insee.vtl.parser.antlr4.runtime.atn;
                                            fr.insee.vtl.parser.antlr4.runtime.dfa;
                                            fr.insee.vtl.parser.antlr4.runtime.misc;
                                            fr.insee.vtl.parser.antlr4.runtime.tree;
                                            fr.insee.vtl.parser.antlr4.runtime.tree.pattern;
                                            fr.insee.vtl.parser.antlr4.runtime.tree.xpath;
                                        </exports>
                                        <opens>fr.insee.vtl.parser;</opens>
                                    </moduleInfo>
                                </module>
                            </modules>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
        </plugins>

        <!-- Needed so that the mvn test goal finds the ANTLR g4 files. -->
        <resources>
            <resource>
                <directory>src/main/resources</directory>
            </resource>
            <resource>
                <directory>src/main/antlr4</directory>
                <includes>
                    <include>**/*.g4</include>
                </includes>
            </resource>
        </resources>
    </build>

</project>
